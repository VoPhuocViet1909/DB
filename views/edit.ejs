<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <title>Sửa Món: <%= item.itemName %></title>
</head>
<body class="container mt-4">
  <h2 class="mb-4">Cập Nhật Món: <strong><%= item.itemName %></strong></h2>

  <% if(errors && errors.length > 0) { %>
    <div class="alert alert-danger">
      <ul class="mb-0"><% errors.forEach(e => { %><li><%= e %></li><% }) %></ul>
    </div>
  <% } %>

  <form action="/edit/<%= item.itemId %>" method="POST" enctype="multipart/form-data" class="card p-4 shadow-sm">
    <input type="hidden" name="oldImageUrl" value="<%= item.imageUrl || '' %>">
    <input type="hidden" name="createdAt" value="<%= item.createdAt || '' %>">

    <div class="mb-3">
      <label class="form-label">Tên món <span class="text-danger">*</span></label>
      <input type="text" name="itemName" class="form-control"
        value="<%= item.itemName || '' %>" required>
    </div>

    <div class="row mb-3">
      <div class="col">
        <label class="form-label">Nhóm món (Category) <span class="text-danger">*</span></label>
        <select name="category" class="form-select" required>
          <% VALID_CATEGORIES.forEach(cat => { %>
            <option value="<%= cat %>" <%= item.category === cat ? 'selected' : '' %>><%= cat %></option>
          <% }) %>
        </select>
      </div>
      <div class="col">
        <label class="form-label">Trạng thái còn bán</label>
        <select name="isAvailable" class="form-select">
          <option value="true" <%= (item.isAvailable === true || item.isAvailable === 'true') ? 'selected' : '' %>>Còn bán</option>
          <option value="false" <%= (item.isAvailable === false || item.isAvailable === 'false') ? 'selected' : '' %>>Hết món</option>
        </select>
      </div>
    </div>

    <div class="row mb-3">
      <div class="col">
        <label class="form-label">Giá gốc (đ) <span class="text-danger">*</span></label>
        <input type="number" name="price" class="form-control"
          value="<%= item.price || '' %>" min="1" required>
      </div>
      <div class="col">
        <label class="form-label">Giảm giá (%) <span class="text-danger">*</span></label>
        <input type="number" name="discountPercent" class="form-control"
          value="<%= item.discountPercent !== undefined ? item.discountPercent : 0 %>" min="0" max="50" required>
      </div>
    </div>

    <div class="mb-4">
      <label class="form-label">Cập nhật ảnh món (để trống giữ ảnh cũ)</label>
      <input type="file" name="image" class="form-control" accept="image/*">
      <% if(item.imageUrl) { %>
        <div class="mt-2">
          <small class="text-muted">Ảnh hiện tại:</small><br>
          <img src="<%= item.imageUrl %>" width="100" class="img-thumbnail mt-1">
        </div>
      <% } %>
    </div>

    <button type="submit" class="btn btn-warning w-100">Cập Nhật</button>
    <a href="/" class="btn btn-secondary w-100 mt-2">Quay Lại</a>
  </form>
</body>
</html>
