<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <title>Quản Lý Món Ăn - CafeMenu</title>
  <style>
    .card-img-top { height: 160px; object-fit: cover; }
    .badge-available { background-color: #198754; }
    .badge-unavailable { background-color: #6c757d; }
  </style>
</head>
<body class="container mt-4 mb-5">
  <h2 class="mb-3">Menu Quán Cafe</h2>

  <div class="d-flex gap-2 mb-3 flex-wrap">
    <% VALID_CATEGORIES.forEach(cat => { %>
      <span class="badge bg-info text-dark fs-6"><%= cat %>: <%= countByCat[cat] %> món còn bán</span>
    <% }) %>
  </div>

  <form method="GET" action="/" class="d-flex gap-2 mb-3 flex-wrap align-items-center">
    <input type="text" name="search" class="form-control" style="max-width:220px"
      placeholder="Tìm theo tên món..." value="<%= typeof search !== 'undefined' ? search : '' %>">
    <select name="category" class="form-select" style="max-width:160px">
      <option value="">Tất cả danh mục</option>
      <% VALID_CATEGORIES.forEach(cat => { %>
        <option value="<%= cat %>" <%= typeof category !== 'undefined' && category === cat ? 'selected' : '' %>><%= cat %></option>
      <% }) %>
    </select>
    <select name="isAvailable" class="form-select" style="max-width:160px">
      <option value="">Tất cả trạng thái</option>
      <option value="true" <%= typeof isAvailable !== 'undefined' && isAvailable === 'true' ? 'selected' : '' %>>Còn bán</option>
      <option value="false" <%= typeof isAvailable !== 'undefined' && isAvailable === 'false' ? 'selected' : '' %>>Hết món</option>
    </select>
    <button class="btn btn-primary" type="submit">Lọc / Tìm</button>
    <a href="/" class="btn btn-outline-secondary">Xóa lọc</a>
  </form>

  <div class="d-flex justify-content-between mb-3">
    <a href="/add" class="btn btn-success">+ Thêm Món</a>
    <button class="btn btn-danger" onclick="deleteSelected()">Xóa các món đã chọn</button>
  </div>

  <form id="deleteForm" action="/delete" method="POST">
    <div class="row g-3">
      <% if(items.length === 0) { %>
        <div class="col-12 text-center text-muted">Không tìm thấy món nào.</div>
      <% } %>
      <% items.forEach(item => { %>
        <div class="col-md-4 col-lg-3">
          <div class="card h-100 shadow-sm">
            <div class="form-check position-absolute m-2">
              <input class="form-check-input" type="checkbox" name="ids" value="<%= item.itemId %>" id="chk_<%= item.itemId %>">
            </div>
            <% if(item.imageUrl) { %>
              <img src="<%= item.imageUrl %>" class="card-img-top" alt="<%= item.itemName %>">
            <% } else { %>
              <div class="card-img-top bg-light d-flex align-items-center justify-content-center text-secondary" style="height:160px;">Không có ảnh</div>
            <% } %>
            <div class="card-body">
              <h6 class="card-title fw-bold"><%= item.itemName %></h6>
              <p class="mb-1 text-muted small">Nhóm: <strong><%= item.category %></strong></p>
              <p class="mb-1">Giá gốc: <span class="text-decoration-line-through text-muted"><%= Number(item.price).toLocaleString('vi-VN') %>đ</span></p>
              <% if(Number(item.discountPercent) > 0) { %>
                <p class="mb-1 text-danger fw-bold">Giảm: <%= item.discountPercent %>% → <strong><%= Math.round(item.salePrice).toLocaleString('vi-VN') %>đ</strong></p>
              <% } else { %>
                <p class="mb-1 fw-bold">Giá bán: <%= Math.round(item.salePrice).toLocaleString('vi-VN') %>đ</p>
              <% } %>
              <div class="mt-2">
                <% if(item.isAvailable === true || item.isAvailable === 'true') { %>
                  <span class="badge badge-available">Còn bán</span>
                <% } else { %>
                  <span class="badge badge-unavailable">Hết món</span>
                <% } %>
              </div>
            </div>
            <div class="card-footer d-flex gap-2">
              <a href="/edit/<%= item.itemId %>" class="btn btn-sm btn-warning flex-fill">Sửa</a>
              <a href="/delete/<%= item.itemId %>" class="btn btn-sm btn-danger flex-fill"
                onclick="return confirm('Xóa món <%= item.itemName %>?')">Xóa</a>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </form>

  <script>
    function deleteSelected() {
      const checked = document.querySelectorAll('input[name="ids"]:checked');
      if (checked.length === 0) { alert("Vui lòng chọn ít nhất 1 món để xóa."); return; }
      if (!confirm(`Bạn có chắc muốn xóa ${checked.length} món đã chọn?`)) return;
      document.getElementById("deleteForm").submit();
    }
  </script>
</body>
</html>
