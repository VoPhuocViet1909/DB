<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <title>Thêm Món Mới</title>
</head>
<body class="container mt-4">
  <h2 class="mb-4">Thêm Món Mới</h2>

  <% if(errors && errors.length > 0) { %>
    <div class="alert alert-danger">
      <ul class="mb-0"><% errors.forEach(e => { %><li><%= e %></li><% }) %></ul>
    </div>
  <% } %>

  <form action="/add" method="POST" enctype="multipart/form-data" class="card p-4 shadow-sm">
    <div class="mb-3">
      <label class="form-label">Tên món <span class="text-danger">*</span></label>
      <input type="text" name="itemName" class="form-control" placeholder="Tên món ăn/thức uống"
        value="<%= item.itemName || '' %>" required>
    </div>

    <div class="row mb-3">
      <div class="col">
        <label class="form-label">Nhóm món (Category) <span class="text-danger">*</span></label>
        <select name="category" class="form-select" required>
          <option value="">-- Chọn nhóm --</option>
          <% VALID_CATEGORIES.forEach(cat => { %>
            <option value="<%= cat %>" <%= item.category === cat ? 'selected' : '' %>><%= cat %></option>
          <% }) %>
        </select>
      </div>
      <div class="col">
        <label class="form-label">Trạng thái</label>
        <select name="isAvailable" class="form-select">
          <option value="true" <%= (!item.isAvailable || item.isAvailable === 'true' || item.isAvailable === true) ? 'selected' : '' %>>Còn bán</option>
          <option value="false" <%= (item.isAvailable === 'false' || item.isAvailable === false) ? 'selected' : '' %>>Hết món</option>
        </select>
      </div>
    </div>

    <div class="row mb-3">
      <div class="col">
        <label class="form-label">Giá gốc (đ) <span class="text-danger">*</span></label>
        <input type="number" name="price" class="form-control" placeholder="Giá gốc > 0"
          value="<%= item.price || '' %>" min="1" required>
      </div>
      <div class="col">
        <label class="form-label">Giảm giá (%) <span class="text-danger">*</span></label>
        <input type="number" name="discountPercent" class="form-control" placeholder="0 đến 50"
          value="<%= item.discountPercent !== undefined ? item.discountPercent : 0 %>" min="0" max="50" required>
      </div>
    </div>

    <div class="mb-4">
      <label class="form-label">Ảnh món ăn (tải lên S3)</label>
      <input type="file" name="image" class="form-control" accept="image/*">
    </div>

    <button type="submit" class="btn btn-success w-100">Thêm Món</button>
    <a href="/" class="btn btn-secondary w-100 mt-2">Quay Lại</a>
  </form>
</body>
</html>
